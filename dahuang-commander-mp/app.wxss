/** Global Cyberpunk Theme stylesheet for Dahuang Commander **/
page {
  background-color: #020617;
  color: #f8fafc;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif, monospace;
  font-size: 14px;
  line-height: 1.5;
  box-sizing: border-box;
}

view, scroll-view, text, input, button {
  box-sizing: border-box;
}

/* Neon Glow Cards */
.cyber-panel {
  background-color: rgba(11, 15, 25, 0.9);
  border: 1rpx solid rgba(6, 182, 212, 0.3);
  border-radius: 12rpx;
  box-shadow: 0 0 20rpx rgba(6, 182, 212, 0.1);
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.glow-cyan {
  box-shadow: 0 0 20rpx rgba(6, 182, 212, 0.25);
  border-color: rgba(6, 182, 212, 0.5);
}

.glow-purple {
  box-shadow: 0 0 20rpx rgba(168, 85, 247, 0.25);
  border-color: rgba(168, 85, 247, 0.5);
}

.glow-emerald {
  box-shadow: 0 0 20rpx rgba(16, 185, 129, 0.25);
  border-color: rgba(16, 185, 129, 0.5);
}

/* Flex layout utilities */
.flex-row {
  display: flex;
  flex-direction: row;
}

.flex-col {
  display: flex;
  flex-direction: column;
}

.align-center {
  align-items: center;
}

.justify-between {
  justify-content: space-between;
}

/* Custom Text Badges */
.badge {
  font-size: 18rpx;
  font-weight: bold;
  padding: 4rpx 10rpx;
  border-radius: 6rpx;
  border: 1rpx solid;
  text-transform: uppercase;
}

.badge-pending {
  color: #64748b;
  border-color: rgba(100, 116, 139, 0.3);
  background-color: rgba(100, 116, 139, 0.1);
}

.badge-processing {
  color: #06b6d4;
  border-color: rgba(6, 182, 212, 0.4);
  background-color: rgba(6, 182, 212, 0.1);
}

.badge-success {
  color: #10b981;
  border-color: rgba(16, 185, 129, 0.4);
  background-color: rgba(16, 185, 129, 0.1);
}

.badge-failed {
  color: #f43f5e;
  border-color: rgba(244, 63, 94, 0.4);
  background-color: rgba(244, 63, 94, 0.1);
}

/* Scrollbars - Hidden/Minimalist */
::-webkit-scrollbar {
  width: 0rpx;
  height: 0rpx;
  color: transparent;
}
