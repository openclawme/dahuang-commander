.container {
  padding: 24rpx;
  background-color: #020617;
  min-height: 100vh;
  box-sizing: border-box;
}

/* Active Profile Card */
.active-agent-card {
  padding: 32rpx;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
}

.card-header {
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
  padding-bottom: 16rpx;
  margin-bottom: 20rpx;
}

.card-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #f8fafc;
}

.agent-profile-detail {
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.avatar-ring-large {
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  border: 4rpx solid #06b6d4;
  background-color: rgba(6, 182, 212, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 0 15rpx rgba(6, 182, 212, 0.3);
}

.avatar-emoji {
  font-size: 50rpx;
}

.profile-meta {
  justify-content: center;
}

.profile-name {
  font-size: 34rpx;
  font-weight: bold;
  color: #f8fafc;
}

.profile-char {
  font-size: 22rpx;
  color: #64748b;
  margin-top: 6rpx;
}

.profile-stats {
  background: rgba(2, 6, 23, 0.6);
  border: 1rpx solid rgba(100, 116, 139, 0.15);
  border-radius: 8rpx;
  padding: 20rpx;
  margin-bottom: 24rpx;
}

.p-stat {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
}

.p-stat-lbl {
  font-size: 20rpx;
  color: #64748b;
  margin-bottom: 6rpx;
}

.p-stat-val {
  font-size: 32rpx;
  font-weight: bold;
  font-family: monospace;
}

.did-block {
  margin-bottom: 24rpx;
}

.did-label {
  font-size: 18rpx;
  color: #475569;
  font-weight: bold;
}

.did-value {
  font-size: 20rpx;
  color: #06b6d4;
  font-family: monospace;
  word-break: break-all;
  margin-top: 6rpx;
}

.token-block {
  background: rgba(2, 6, 23, 0.5);
  border: 1rpx solid rgba(255, 255, 255, 0.05);
  padding: 14rpx 20rpx;
  border-radius: 8rpx;
  margin-bottom: 24rpx;
  gap: 16rpx;
}

.token-preview {
  font-size: 20rpx;
  color: #475569;
  flex: 1;
}

.copy-btn {
  background: rgba(6, 182, 212, 0.1);
  border: 1rpx solid #06b6d4;
  color: #06b6d4;
  font-size: 20rpx;
  font-weight: bold;
  padding: 0 16rpx;
  height: 48rpx;
  line-height: 48rpx;
  border-radius: 4rpx;
  margin: 0;
}

.copy-btn::after {
  border: none;
}

.copy-btn:active {
  background: rgba(6, 182, 212, 0.25);
}

.logout-btn {
  background: rgba(244, 63, 94, 0.1);
  border: 1rpx solid rgba(244, 63, 94, 0.4);
  color: #f43f5e;
  font-size: 24rpx;
  font-weight: bold;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 8rpx;
  text-align: center;
  width: 100%;
}

.logout-btn::after {
  border: none;
}

.logout-btn:active {
  background: rgba(244, 63, 94, 0.2);
}

/* Unlogged card styles */
.unlogin-icon {
  font-size: 100rpx;
  margin-bottom: 16rpx;
}

.unlogin-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #a855f7;
  text-shadow: 0 0 10rpx rgba(168, 85, 247, 0.4);
}

.unlogin-desc {
  font-size: 22rpx;
  color: #64748b;
  margin-top: 12rpx;
  line-height: 1.6;
  padding: 0 16rpx;
}

/* Agents Panel */
.panel-desc {
  font-size: 20rpx;
  color: #64748b;
  margin-top: 6rpx;
  line-height: 1.4;
}

.loading-spin {
  padding: 40rpx 0;
}

.spin-text {
  font-size: 24rpx;
  color: #475569;
}

.agents-scroll {
  height: 350rpx;
  margin-top: 20rpx;
}

.agents-grid {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 16rpx;
}

.agent-grid-item {
  width: calc(33.33% - 11rpx);
  background: rgba(2, 6, 23, 0.5);
  border: 1rpx solid rgba(168, 85, 247, 0.2);
  border-radius: 8rpx;
  padding: 16rpx;
  transition: all 0.2s ease;
}

.agent-item-hover {
  border-color: #a855f7;
  background: rgba(168, 85, 247, 0.1);
}

.grid-avatar {
  font-size: 40rpx;
  margin-bottom: 10rpx;
}

.grid-name {
  font-size: 22rpx;
  font-weight: bold;
  color: #e2e8f0;
  text-align: center;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  width: 100%;
}

.grid-karma {
  font-size: 16rpx;
  color: #a855f7;
  text-align: center;
  font-family: monospace;
  margin-top: 4rpx;
}

.empty-agents {
  padding: 80rpx 0;
}

.empty-icon {
  font-size: 60rpx;
  margin-bottom: 10rpx;
}

.empty-text {
  font-size: 22rpx;
  color: #334155;
}

.register-toggle-btn {
  background: linear-gradient(135deg, #a855f7, #9333ea);
  color: #ffffff;
  font-size: 24rpx;
  font-weight: bold;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 8rpx;
  border: none;
  width: 100%;
  margin-top: 24rpx;
  box-shadow: 0 0 15rpx rgba(168, 85, 247, 0.4);
}

.register-toggle-btn::after {
  border: none;
}

.register-toggle-btn:active {
  opacity: 0.8;
}

/* Import Panel */
.token-textarea {
  width: 100%;
  height: 120rpx;
  background: rgba(2, 6, 23, 0.8);
  border: 1rpx solid rgba(16, 185, 129, 0.3);
  border-radius: 8rpx;
  padding: 16rpx;
  font-size: 22rpx;
  color: #f8fafc;
  font-family: monospace;
  margin-top: 20rpx;
  box-sizing: border-box;
}

.token-placeholder {
  color: #475569;
  font-size: 22rpx;
}

.import-submit-btn {
  background: linear-gradient(135deg, #10b981, #059669);
  color: #020617;
  font-size: 24rpx;
  font-weight: bold;
  height: 70rpx;
  line-height: 70rpx;
  border-radius: 6rpx;
  border: none;
  width: 100%;
  margin-top: 20rpx;
  box-shadow: 0 0 12rpx rgba(16, 185, 129, 0.3);
}

.import-submit-btn::after {
  border: none;
}

.import-submit-btn:active {
  opacity: 0.8;
}

/* Register Form Panel */
.register-form-panel {
  display: flex;
  flex-direction: column;
}

.border-bottom {
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
  padding-bottom: 16rpx;
  margin-bottom: 24rpx;
}

.form-container {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.form-item {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.form-label {
  font-size: 22rpx;
  font-weight: bold;
  color: #06b6d4;
}

.form-input {
  height: 70rpx;
  background: rgba(2, 6, 23, 0.8);
  border: 1rpx solid rgba(6, 182, 212, 0.3);
  border-radius: 6rpx;
  padding: 0 20rpx;
  font-size: 24rpx;
  color: #f8fafc;
  width: 100%;
  box-sizing: border-box;
}

.form-input:focus {
  border-color: #06b6d4;
}

.form-textarea-small {
  height: 100rpx;
  background: rgba(2, 6, 23, 0.8);
  border: 1rpx solid rgba(6, 182, 212, 0.3);
  border-radius: 6rpx;
  padding: 16rpx 20rpx;
  font-size: 24rpx;
  color: #f8fafc;
  width: 100%;
  box-sizing: border-box;
}

.form-textarea {
  height: 160rpx;
  background: rgba(2, 6, 23, 0.8);
  border: 1rpx solid rgba(6, 182, 212, 0.3);
  border-radius: 6rpx;
  padding: 16rpx 20rpx;
  font-size: 24rpx;
  color: #f8fafc;
  width: 100%;
  box-sizing: border-box;
}

.iq-challenge-badge {
  background: rgba(6, 182, 212, 0.08);
  border: 1rpx solid rgba(6, 182, 212, 0.3);
  border-radius: 6rpx;
  padding: 14rpx 20rpx;
  margin-top: 10rpx;
}

.iq-badge-dot {
  color: #06b6d4;
  font-size: 24rpx;
  margin-right: 12rpx;
  animation: pulse-cyan 1.5s infinite alternate;
}

.iq-badge-text {
  font-size: 18rpx;
  color: #06b6d4;
  font-weight: bold;
}

@keyframes pulse-cyan {
  0% {
    opacity: 0.3;
  }
  100% {
    opacity: 1;
    text-shadow: 0 0 10rpx #06b6d4;
  }
}

.pledge-notice {
  margin-top: 10rpx;
  line-height: 1.5;
  padding: 16rpx;
  background: rgba(255, 255, 255, 0.02);
  border-radius: 6rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.05);
}

.pledge-title {
  font-size: 20rpx;
  font-weight: bold;
  color: #cbd5e1;
}

.pledge-text {
  font-size: 18rpx;
  color: #475569;
}

.button-row {
  gap: 20rpx;
  margin-top: 10rpx;
}

.form-cancel-btn {
  flex: 1;
  background: rgba(255, 255, 255, 0.05);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  color: #94a3b8;
  font-size: 24rpx;
  font-weight: bold;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 8rpx;
  text-align: center;
  margin: 0;
}

.form-cancel-btn::after {
  border: none;
}

.form-cancel-btn:active {
  background: rgba(255, 255, 255, 0.1);
}

.form-submit-btn {
  flex: 1;
  background: linear-gradient(135deg, #06b6d4, #0891b2);
  color: #020617;
  font-size: 24rpx;
  font-weight: bold;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 8rpx;
  border: none;
  text-align: center;
  margin: 0;
  box-shadow: 0 0 15rpx rgba(6, 182, 212, 0.4);
}

.form-submit-btn::after {
  border: none;
}

.form-submit-btn:active {
  opacity: 0.8;
}
