.container {
  height: 100vh;
  background-color: #020617;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

.msg-scroll {
  flex: 1;
  min-height: 0;
  padding: 24rpx;
  box-sizing: border-box;
}

.msg-list {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
  padding-bottom: 40rpx;
}

.msg-item {
  width: 100%;
  align-items: flex-start;
  gap: 16rpx;
}

.msg-me {
  flex-direction: row-reverse;
}

.msg-other {
  flex-direction: row;
}

.msg-avatar {
  width: 70rpx;
  height: 70rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  background-color: rgba(6, 182, 212, 0.1);
  border: 2rpx solid #06b6d4;
  box-shadow: 0 0 10rpx rgba(6, 182, 212, 0.3);
}

.msg-me .msg-avatar {
  background-color: rgba(168, 85, 247, 0.1);
  border: 2rpx solid #a855f7;
  box-shadow: 0 0 10rpx rgba(168, 85, 247, 0.3);
}

.avatar-char {
  font-size: 32rpx;
}

.msg-content-wrapper {
  max-width: 70%;
}

.msg-me .msg-content-wrapper {
  align-items: flex-end;
}

.msg-other .msg-content-wrapper {
  align-items: flex-start;
}

.sender-name {
  font-size: 20rpx;
  color: #64748b;
  margin-bottom: 6rpx;
  font-weight: bold;
}

.msg-bubble {
  padding: 16rpx 24rpx;
  line-height: 1.5;
  font-size: 26rpx;
  word-break: break-all;
  word-wrap: break-word;
  text-align: left;
}

.bubble-me-glow {
  background-color: rgba(168, 85, 247, 0.15);
  border: 1rpx solid rgba(168, 85, 247, 0.4);
  color: #f8fafc;
  box-shadow: 0 0 15rpx rgba(168, 85, 247, 0.1);
  border-radius: 16rpx 0 16rpx 16rpx;
}

.bubble-other-glow {
  background-color: rgba(6, 182, 212, 0.15);
  border: 1rpx solid rgba(6, 182, 212, 0.4);
  color: #e2e8f0;
  box-shadow: 0 0 15rpx rgba(6, 182, 212, 0.1);
  border-radius: 0 16rpx 16rpx 16rpx;
}

.msg-body {
  font-size: 26rpx;
}

.msg-time {
  font-size: 18rpx;
  color: #475569;
  margin-top: 6rpx;
  font-family: monospace;
}

/* Chat Footer Input Styles */
.placeholder-bottom {
  height: 160rpx;
  flex-shrink: 0;
}

.chat-footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #0b0f19;
  border-top: 1rpx solid rgba(6, 182, 212, 0.2);
  padding: 24rpx 32rpx;
  box-shadow: 0 -10rpx 30rpx rgba(0, 0, 0, 0.5);
  z-index: 100;
}

.chat-footer .input-container {
  background: rgba(2, 6, 23, 0.9);
  border: 1rpx solid rgba(100, 116, 139, 0.3);
  border-radius: 8rpx;
  padding: 10rpx 20rpx;
  flex: 1;
}

.chat-input {
  flex: 1;
  background: transparent;
  border: none;
  color: #f8fafc;
  font-size: 26rpx;
  height: 60rpx;
  line-height: 60rpx;
  padding: 0;
}

.chat-placeholder {
  color: #475569;
  font-size: 24rpx;
}

.send-btn {
  background: linear-gradient(135deg, #a855f7, #9333ea);
  color: #ffffff;
  font-size: 24rpx;
  font-weight: bold;
  border-radius: 6rpx;
  padding: 0 28rpx;
  height: 60rpx;
  line-height: 60rpx;
  margin: 0 0 0 16rpx;
  border: none;
  box-shadow: 0 0 12rpx rgba(168, 85, 247, 0.4);
}

.send-btn::after {
  border: none;
}

.send-btn:active {
  opacity: 0.8;
}
